---
import Base from '../layouts/Base.astro';
import { SUPPORT_EMAIL } from '../site';
---

<Base
  path="/impressum"
  title="Impressum — Voxhelm"
  description="Legal notice for Voxhelm, per §5 of the German Digital Services Act (DDG)."
>
  <main class="mx-auto max-w-2xl px-5 py-16 sm:px-8 sm:py-24">
    <a href="/" class="text-[13px] font-light uppercase tracking-[0.2em] text-white/50 transition-colors hover:text-white">← Back</a>
    <h1 class="font-garamond mt-8 text-4xl font-normal text-white sm:text-5xl">Impressum</h1>
    <p class="mt-3 text-[13px] font-light italic text-white/40">Legal notice per §5 DDG (Digitale-Dienste-Gesetz).</p>

    <div class="mt-10 space-y-8 text-[15px] font-light leading-relaxed text-white/70">
      <div>
        <h2 class="mb-3 text-lg font-medium text-white">Information according to §5 DDG</h2>
        <p>
          Mohammed Jaseel Kunnathodika<br />
          trading as Voxhelm<br />
          Almandring 14A, Zimmer 31<br />
          70569 Stuttgart (Vaihingen)<br />
          Germany
        </p>
        <p class="mt-3 text-[13px] text-white/45">
          Voxhelm is currently operated as an individual (sole proprietor); business registration is in progress.
        </p>
      </div>

      <div>
        <h2 class="mb-3 text-lg font-medium text-white">Contact</h2>
        <p>
          Email: <a class="text-white underline underline-offset-4" href={`mailto:${SUPPORT_EMAIL}`}>{SUPPORT_EMAIL}</a>
        </p>
      </div>

      <div>
        <h2 class="mb-3 text-lg font-medium text-white">Responsible for content per §18(2) MStV</h2>
        <p>
          Mohammed Jaseel Kunnathodika, address as above.
        </p>
      </div>

      <div>
        <h2 class="mb-3 text-lg font-medium text-white">EU dispute resolution</h2>
        <p>
          The European Commission provides a platform for online dispute resolution (ODR):
          <a class="text-white underline underline-offset-4" href="https://ec.europa.eu/consumers/odr/" target="_blank" rel="noopener noreferrer">ec.europa.eu/consumers/odr</a>.
          We are not obliged to and do not participate in dispute resolution proceedings before a consumer arbitration board.
        </p>
      </div>
    </div>
  </main>
</Base>
