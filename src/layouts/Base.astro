---
import '../styles/global.css';

export interface Props {
  title?: string;
  description?: string;
  path?: string;
  /** Extra JSON-LD blocks (e.g. FAQPage) merged with the site-wide schema. */
  schema?: Record<string, unknown>[];
  noindex?: boolean;
}

const {
  title = 'Voxhelm — An AI that lives in your PC.',
  description =
    'Voxhelm is an AI voice assistant that lives on your Windows PC. Speak, and it sees your screen, opens your apps, drives your browser and handles your files — and it teaches you, drawing on screen to show you how.',
  path = '/',
  schema = [],
  noindex = false,
} = Astro.props;

const SITE = 'https://voxhelm.de';
const canonical = new URL(path, SITE).href;
const ogImage = new URL('/og.png', SITE).href;

// Site-wide structured data — what Google + AI agents read to "understand" the
// product. Always emitted; pages can pass extra blocks (e.g. FAQPage).
const baseSchema: Record<string, unknown>[] = [
  {
    '@context': 'https://schema.org',
    '@type': 'Organization',
    name: 'Voxhelm',
    url: SITE,
    logo: `${SITE}/icon-512.png`,
    description,
  },
  {
    '@context': 'https://schema.org',
    '@type': 'WebSite',
    name: 'Voxhelm',
    url: SITE,
  },
  {
    '@context': 'https://schema.org',
    '@type': 'SoftwareApplication',
    name: 'Voxhelm',
    applicationCategory: 'UtilitiesApplication',
    operatingSystem: 'Windows 10, Windows 11',
    description,
    url: SITE,
    downloadUrl: `${SITE}/downloads/Voxhelm-Setup.exe`,
    // Tracks the shipped app version (CLAUDE.md keeps these in sync). It had
    // drifted three releases behind — 0.5.0/0.5.1/0.5.2 all shipped against
    // '0.4.4'. Bump this with every release that reaches users.
    softwareVersion: '0.6.0',
    featureList: [
      'Voice control of Windows by holding a key',
      'Meeting notes: decisions, action items and transcript, written when the call ends',
      'Dictation: speak in any app and have the finished sentence typed',
      'Screen-aware: acts on what is in front of you',
      'On-screen guidance: draws the steps rather than describing them',
    ],
    offers: [
      {
        '@type': 'Offer',
        name: 'Free',
        price: '0',
        priceCurrency: 'EUR',
        category: 'subscription',
      },
      {
        '@type': 'Offer',
        name: 'Pro',
        price: '15',
        priceCurrency: 'EUR',
        category: 'subscription',
      },
      {
        '@type': 'Offer',
        name: 'Elite',
        price: '30',
        priceCurrency: 'EUR',
        category: 'subscription',
      },
    ],
  },
];
const allSchema = [...baseSchema, ...schema];
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{title}</title>
    <meta name="description" content={description} />
    <link rel="canonical" href={canonical} />
    {noindex && <meta name="robots" content="noindex, nofollow" />}
    <meta name="theme-color" content="#0E7C66" />
    <meta name="generator" content={Astro.generator} />
    <link rel="icon" href="/favicon.svg" type="image/svg+xml" />
    <link rel="icon" href="/favicon.ico" sizes="32x32" />
    <link rel="apple-touch-icon" href="/apple-touch-icon.png" />

    <!-- Open Graph. og:image MUST be a raster — X, Slack, LinkedIn, Discord and
         iMessage all refuse to render an SVG preview and fall back to a blank card. -->
    <meta property="og:type" content="website" />
    <meta property="og:site_name" content="Voxhelm" />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonical} />
    <meta property="og:image" content={ogImage} />
    <meta property="og:image:type" content="image/png" />
    <meta property="og:image:width" content="1200" />
    <meta property="og:image:height" content="630" />
    <meta property="og:image:alt" content="Voxhelm — an AI that lives in your PC." />

    <!-- Twitter -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogImage} />

    <!-- Fonts: Garamond (display) + Geist (body) -->
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link rel="preconnect" href="https://db.onlinewebfonts.com" crossorigin />
    <link
      href="https://db.onlinewebfonts.com/c/2bf40ab72ea4897a3fd9b6e48b233a19?family=Garamond"
      rel="stylesheet"
    />
    <link
      href="https://fonts.googleapis.com/css2?family=Geist:wght@300;400;500&display=swap"
      rel="stylesheet"
    />

    {/* Structured data for search engines + AI agents */}
    {
      allSchema.map((block) => (
        <script type="application/ld+json" set:html={JSON.stringify(block)} />
      ))
    }
  </head>
  <body>
    <slot />
  </body>
</html>
